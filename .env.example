# Frontend Experience Orchestrator
# Copy this file to `.env.local` and fill the values you actually use.

# -----------------------------------------------------------------------------
# Persistence gateway
# local      -> browser IndexedDB only
# cloud      -> legacy custom HTTP gateway / mock server
# supabase   -> direct Supabase Auth + Postgres
# -----------------------------------------------------------------------------
VITE_BUILDER_GATEWAY_MODE=local

# -----------------------------------------------------------------------------
# Legacy custom cloud gateway (optional)
# -----------------------------------------------------------------------------
VITE_BUILDER_API_BASE_URL=http://127.0.0.1:3001
VITE_BUILDER_AUTH_MODE=bearer
VITE_BUILDER_STATIC_TOKEN=
VITE_BUILDER_VIEWER_NAME=Cloud Builder Demo

# -----------------------------------------------------------------------------
# Supabase direct gateway (recommended for real multi-user persistence)
# The app only needs the public project URL + anon key on the frontend.
# Do NOT place the service role key in this file.
# After the first successful login, Supabase session persistence lets the app
# reconnect automatically on the next startup.
# VITE_SUPABASE_AUTH_PROFILE controls editor guidance only:
# development -> optimize for fast local iteration
# production  -> optimize for real verified users + SMTP
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_AUTH_PROFILE=production
